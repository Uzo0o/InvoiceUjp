<Window x:Class="InvoiceProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:InvoiceProject.Views" 
        Title="Integriti E-Fakturi" 
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        ResizeMode="CanResize"
        FontFamily="{StaticResource Poppins}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"> 

    <Window.Resources>
        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/> <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="Transparent"/> <Setter Property="BorderThickness" Value="0,0,4,0"/> <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="MainBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            
                            <StackPanel Orientation="Horizontal" Margin="25,0,0,0">
                                
                                <Border x:Name="IconBox" Width="32" Height="32" CornerRadius="8" Background="#E9ECEF" VerticalAlignment="Center">
                                    <Path x:Name="IconPath" Data="{TemplateBinding Tag}" Stretch="Uniform" Fill="Black" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <TextBlock x:Name="BtnText" Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                
                            </StackPanel>
                        </Border>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#E1EBF9"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#1B3A6B"/> <Setter TargetName="BtnText" Property="Foreground" Value="#479A9E"/>     <Setter TargetName="IconBox" Property="Background" Value="#69E2E8"/>     <Setter TargetName="IconPath" Property="Fill" Value="White"/>            </Trigger>
                            
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="MainBorder" Property="Background" Value="#F8F9FA"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WindowControlBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Path Data="{TemplateBinding Tag}" 
                                  Fill="{TemplateBinding Foreground}" 
                                  Stretch="Uniform" 
                                  Width="10" Height="10" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyanWindowBtnStyle" TargetType="Button" BasedOn="{StaticResource WindowControlBtnStyle}">
            <Setter Property="Background" Value="#1B3A6B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4CD3DA"/> </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RedWindowBtnStyle" TargetType="Button" BasedOn="{StaticResource WindowControlBtnStyle}">
            <Setter Property="Background" Value="#FF6B6B"/> <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/> </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="24" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border Background="White" CornerRadius="24" ClipToBounds="True">
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/> <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/> <RowDefinition Height="*"/>  </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0">
                    <TextBlock Text="INTEGRITI" FontWeight="Black" FontSize="20" Foreground="#212529" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,20,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                    
                    <RadioButton Content="New Invoice" Tag="{StaticResource Document}" Style="{StaticResource SidebarTabStyle}" IsChecked="True"/>
                    <RadioButton Content="Client List" Tag="{StaticResource Settings}" Style="{StaticResource SidebarTabStyle}"/>
                    <RadioButton Content="Invoice History" Tag="{StaticResource Settings}" Style="{StaticResource SidebarTabStyle}"/>
                    
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/> <RowDefinition Height="*"/>  </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="White">
                    
                    <Border BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="Create New Invoice" VerticalAlignment="Center" Margin="30,0,0,0" FontWeight="Bold" Foreground="#212529" FontSize="18"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True" Margin="0,0,15,0">
                                
                                <Button Click="Minimize_Click" 
                                        Style="{StaticResource CyanWindowBtnStyle}" 
                                        Tag="{StaticResource Dropdown}"/>
                                
                                <Button Click="Maximize_Click"> <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource CyanWindowBtnStyle}">
                                            <Setter Property="Tag" Value="{StaticResource Expand}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                                    <Setter Property="Tag" Value="{StaticResource Shrink}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <Button Click="Close_Click" 
                                        Style="{StaticResource RedWindowBtnStyle}" 
                                        Tag="{StaticResource Close}" 
                                        Margin="24,0,0,0"/> </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" Background="#E1EBF9">
                    <views:InvoiceEntryView />
                </Grid>
                
            </Grid>
        </Grid>
    </Border>
</Window>