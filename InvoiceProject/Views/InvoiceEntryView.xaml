<UserControl x:Class="InvoiceProject.Views.InvoiceEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="White">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450" /> <ColumnDefinition Width="20" />  <ColumnDefinition Width="*" />   </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <StackPanel>
                
                <TextBlock Text="Invoice Header Details" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Content="Invoice Number:" Grid.Row="0" Grid.Column="0"/>
                    <TextBox Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="0" Margin="0,0,5,10"/>

                    <Label Content="Doc Type:" Grid.Row="0" Grid.Column="1" Margin="5,0,0,0"/>
                    <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedDocumentType}" Grid.Row="1" Grid.Column="1" Margin="5,0,0,10">
                        <ComboBoxItem Content="Standard Invoice (100)" Tag="100" IsSelected="True"/>
                        <ComboBoxItem Content="Credit Note (380)" Tag="380"/>
                        <ComboBoxItem Content="Debit Note (383)" Tag="383"/>
                    </ComboBox>

                    <Label Content="Issue Date:" Grid.Row="2" Grid.Column="0"/>
                    <DatePicker SelectedDate="{Binding InvoiceDate}" Grid.Row="3" Grid.Column="0" Margin="0,0,5,10"/>

                    <Label Content="Turnover Date:" Grid.Row="2" Grid.Column="1" Margin="5,0,0,0"/>
                    <DatePicker SelectedDate="{Binding TurnoverDate}" Grid.Row="3" Grid.Column="1" Margin="5,0,0,10"/>
                </Grid>

                <Separator Margin="0,10,0,15" />

                <TextBlock Text="Buyer Information" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <Label Content="Quick Search (Local Address Book):" Foreground="DarkSlateGray" FontWeight="SemiBold"/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchLocalClientsCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Search" Command="{Binding SearchLocalClientsCommand}" Grid.Column="1" Margin="5,0,0,0"/>
                </Grid>

                <ListBox ItemsSource="{Binding SearchResults}" 
                         SelectedItem="{Binding SelectedClient}" 
                         DisplayMemberPath="Name" 
                         MaxHeight="100" 
                         Margin="0,0,0,15">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <TextBlock Text="- OR ADD NEW CLIENT VIA UJP -" HorizontalAlignment="Center" Foreground="Gray" Margin="0,5,0,10" FontSize="11"/>

                <Label Content="Buyer EDB (Tax Number):" />
                <TextBox Text="{Binding BuyerEdb, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Lookup in UJP API" Command="{Binding LookupCompanyCommand}" Margin="0,10,0,10" Padding="5"/>

                <Label Content="Official Buyer Name:" />
                <TextBox Text="{Binding BuyerName}" IsReadOnly="True" Background="#EAEAEA" Margin="0,0,0,10"/>
                
                <TextBlock Text="{Binding StatusMessage}" Foreground="Blue" FontWeight="Bold" TextWrapping="Wrap"/>
                <Button Content="SUBMIT INVOICE" 
                        Command="{Binding SubmitInvoiceCommand}" 
                        Height="40" 
                        FontSize="16" 
                        FontWeight="Bold" 
                        Background="#28A745" 
                        Foreground="White" 
                        Margin="0,20,0,0" 
                        BorderThickness="0" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Invoice Line Items" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Grid.Row="0"/>
            
            <DataGrid ItemsSource="{Binding InvoiceItems}" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      Grid.Row="1" 
                      Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding LineNo}" IsReadOnly="True" Width="30"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Desc, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                    
                    <DataGridComboBoxColumn Header="DDV" 
                                            SelectedItemBinding="{Binding TaxIndicator, UpdateSourceTrigger=PropertyChanged}" 
                                            Width="80">
                        <DataGridComboBoxColumn.ItemsSource>
                            <x:Array Type="system:String" xmlns:system="clr-namespace:System;assembly=mscorlib">
                                <system:String>18%</system:String>
                                <system:String>5%</system:String>
                                <system:String>DDV-G</system:String>
                            </x:Array>
                        </DataGridComboBoxColumn.ItemsSource>
                    </DataGridComboBoxColumn>

                    <DataGridTextColumn Header="Total" Binding="{Binding RowGrossTotal, StringFormat={}{0:N2}}" IsReadOnly="True" Width="90" FontWeight="Bold"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /> <ColumnDefinition Width="200" /> </Grid.ColumnDefinitions>

                <Button Content="+ Add Item" 
                        Command="{Binding AddBlankItemCommand}" 
                        Width="100" Height="30"
                        HorizontalAlignment="Left"
                        Grid.Column="0"/>

                <Grid Grid.Column="1" Background="#F8F9FA" Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Subtotal:" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right" Margin="5"/>
                    <TextBlock Text="{Binding NetAmount, StringFormat={}{0:N2} MKD}" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Margin="5,5,0,5"/>

                    <TextBlock Text="VAT (DDV-G):" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right" Margin="5"/>
                    <TextBlock Text="{Binding VatAmount, StringFormat={}{0:N2} MKD}" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" Margin="5,5,0,5"/>

                    <TextBlock Text="TOTAL:" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Right" Margin="5,10,5,5" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding GrossAmount, StringFormat={}{0:N2} MKD}" Grid.Row="2" Grid.Column="1" FontWeight="Bold" FontSize="14" Foreground="#0078D7" Margin="5,10,0,5"/>
                </Grid>
            </Grid>
        </Grid>

    </Grid>
</UserControl>