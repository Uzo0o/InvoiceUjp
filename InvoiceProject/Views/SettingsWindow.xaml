<Window x:Class="InvoiceProject.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Initial Setup - E-Fakturi" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <StackPanel Margin="20">
        <TextBlock Text="Software Setup" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <Label Content="1. Select Digital Certificate Source:" FontWeight="Bold"/>
        
        <Grid Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding CertThumbprint, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Background="#EEEEEE" Grid.Column="0"/>
            <Button Content="Load USB" Command="{Binding SelectUsbCertificateCommand}" Grid.Column="1" Margin="5,0,0,0"/>
        </Grid>

        <TextBlock Text="- OR -" HorizontalAlignment="Center" Foreground="Gray" Margin="0,5,0,5" FontWeight="Bold"/>

        <Grid Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding CertPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Background="#EEEEEE" Grid.Column="0"/>
            <Button Content="Browse .pfx" Command="{Binding BrowseCertificateCommand}" Grid.Column="1" Margin="5,0,0,0"/>
        </Grid>
        
        <Label Content="PFX Password (leave blank if USB):" Margin="0,5,0,0"/>
        <TextBox Text="{Binding CertPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

        <Label Content="2. Your Company EDB:" FontWeight="Bold"/>
        <TextBox Text="{Binding SellerEdb, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>
        
        <Label Content="3. EUJP-ID (From Portal):" FontWeight="Bold"/>
        <TextBox Text="{Binding EujpId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

        <Button Content="Verify &amp; Save Setup" 
                Command="{Binding SaveAndVerifyCommand}" 
                Height="35" FontSize="14" FontWeight="Bold" 
                Background="#0078D7" Foreground="White" BorderThickness="0"/>

        <TextBlock Text="{Binding StatusMessage}" Margin="0,15,0,0" Foreground="Red" TextWrapping="Wrap" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>